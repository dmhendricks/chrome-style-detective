{
  "name": "style-detective",
  "private": true,
  "version": "1.8.0",
  "type": "module",
  "description": "A simple CSS property viewer for Google Chrome.",
  "license": "GPL-2.0",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "overrides": {
    "rollup": "^4.60.0"
  },
  "allowScripts": {
    "@parcel/watcher@2.6.0": true,
    "fsevents@2.3.3": true
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1"
  }
}
