{
    "name": "CSS Quick Viewer",
    "manifest_version": 3,
    "version": "1.8.0",
    "description": "Displays a floating panel of any hovered element's CSS properties.",
    "icons": {
        "16": "img/16.png",
        "22": "img/22.png",
        "24": "img/24.png",
        "32": "img/32.png",
        "48": "img/48.png"
    },
    "options_page": "src/options/options.html",
    "background": {
        "service_worker": "src/background.ts",
        "type": "module"
    },
    "action": {
        "default_icon": "img/16.png",
        "default_title": "CSS Quick Viewer"
    },
    "permissions": [
        "scripting",
        "contextMenus"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "file://*/*"
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "windows": "Ctrl+Shift+S",
                "mac": "Command+Shift+S",
                "chromeos": "Ctrl+Shift+S",
                "linux": "Ctrl+Shift+S"
            }
        }
    }
}
